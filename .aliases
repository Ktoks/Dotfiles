#!/usr/bin/env bash
alias aliases='alias | grep -E "config|ls|hx|src"'
alias config='git --git-dir=$HOME/.cfg/ --work-tree=$HOME'
alias src="source ~/.bashrc"

if ls --color >/dev/null 2>&1; then
  alias ls='ls --color=auto -A'
else # ls alias for BSD
  alias ls='ls -G -A'
fi
alias sl="ls"
alias ll="ls -ho"
alias lls="ll -tr"
alias lsl="lls "
alias lsls="lls "
[ ! "$(command -v  hx)" ] && alias hx="helix "
[ "$(command -v  go)" ] && alias gobld="go build -ldflags \"-w -s\""
